# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/quantumtrade
# For local dev without Docker, use SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./quantumtrade.db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (REQUIRED) ───────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── AI Copilot (REQUIRED for real AI) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Market Data (optional, Yahoo Finance is free) ─────────────
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
